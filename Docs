# install-adcs.ps1
# Descrição: Instala o role Active Directory Certificate Services no Windows Server 2022
# Uso: Execute como Administrador no servidor DC01
# Aviso: Apenas para uso em ambiente de laboratório
 
#Requires -RunAsAdministrator
 
Write-Host "========================================" -ForegroundColor Cyan
Write-Host "  Instalando Active Directory Certificate Services" -ForegroundColor Cyan
Write-Host "========================================" -ForegroundColor Cyan
 
# Instala o role AD CS com a feature Certification Authority
try {
    Install-WindowsFeature -Name ADCS-Cert-Authority `
        -IncludeManagementTools `
        -Verbose
 
    Write-Host "[OK] Role AD CS instalado com sucesso!" -ForegroundColor Green
} catch {
    Write-Host "[ERRO] Falha ao instalar o role: $_" -ForegroundColor Red
    exit 1
}
 
Write-Host ""
Write-Host "Próximo passo: Execute configure-ca.ps1 para configurar a CA Raiz." -ForegroundColor Yellow
